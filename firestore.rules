rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isPublicRecord(data) {
      return data.visibility == "public" || data.isPublic == true;
    }

    function validOriginalLanguage(data) {
      return !data.keys().hasAny(["originalLanguage"])
        || data.originalLanguage in ["en", "zh", "es"];
    }

    function validRecordIdentity(data) {
      return !data.keys().hasAny(["recordIdentityMode"])
        || data.recordIdentityMode in ["account", "anonymous"];
    }

    function validRecordMetadata(data) {
      return validOriginalLanguage(data) && validRecordIdentity(data);
    }

    match /Records/{recordId} {
      allow get, list: if isPublicRecord(resource.data) || isOwner(resource.data.ownerId);

      allow create: if isOwner(request.resource.data.ownerId)
        && validRecordMetadata(request.resource.data);

      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId
        && validRecordMetadata(request.resource.data);

      allow delete: if isOwner(resource.data.ownerId);
    }

    match /users/{userId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;

      match /savedRecords/{recordId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && validRecordMetadata(request.resource.data);
      }

      match /collections/{collectionId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;

        match /records/{recordId} {
          allow read, delete: if isSignedIn() && request.auth.uid == userId;
          allow create, update: if isSignedIn()
            && request.auth.uid == userId
            && validRecordMetadata(request.resource.data);
        }
      }
    }
  }
}
