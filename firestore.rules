rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isAnonymousAuth() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    function isPublicRecord(data) {
      return data.visibility == "public" || data.isPublic == true;
    }

    function recordRequiresAdult(data) {
      return (data.keys().hasAny(["adultContent"]) && data.adultContent == true)
        || (data.keys().hasAny(["minimumViewerAge"]) && data.minimumViewerAge >= 18);
    }

    function isAgeVerifiedAdult() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.age >= 18;
    }

    function canReadPublicRecord(data) {
      return isPublicRecord(data)
        && (!recordRequiresAdult(data) || isAgeVerifiedAdult());
    }

    function validOriginalLanguage(data) {
      return !data.keys().hasAny(["originalLanguage"])
        || data.originalLanguage in ["en", "zh", "es"];
    }

    function validRecordIdentity(data) {
      return !data.keys().hasAny(["recordIdentityMode"])
        || data.recordIdentityMode in ["account", "anonymous"];
    }

    function validAnonymousLock(data) {
      return !data.keys().hasAny(["anonymousLocked"])
        || data.anonymousLocked is bool;
    }

    function validRecordCreateMode(data) {
      return (isAnonymousAuth()
          && data.keys().hasAny(["anonymousLocked"])
          && data.anonymousLocked == true
          && (!data.keys().hasAny(["recordIdentityMode"])
            || data.recordIdentityMode == "anonymous"))
        || (!isAnonymousAuth()
          && (!data.keys().hasAny(["anonymousLocked"])
            || data.anonymousLocked == false));
    }

    function isNotAnonymousLocked(data) {
      return !data.keys().hasAny(["anonymousLocked"])
        || data.anonymousLocked != true;
    }

    function anonymousLockUnchanged() {
      return (!resource.data.keys().hasAny(["anonymousLocked"])
          && !request.resource.data.keys().hasAny(["anonymousLocked"]))
        || (resource.data.keys().hasAny(["anonymousLocked"])
          && request.resource.data.keys().hasAny(["anonymousLocked"])
          && request.resource.data.anonymousLocked == resource.data.anonymousLocked);
    }

    function validAdultMetadata(data) {
      return (!data.keys().hasAny(["adultContent"]) || data.adultContent is bool)
        && (!data.keys().hasAny(["minimumViewerAge"])
          || (data.minimumViewerAge is int
            && data.minimumViewerAge >= 0
            && data.minimumViewerAge <= 120))
        && (!data.keys().hasAll(["adultContent", "minimumViewerAge"])
          || data.adultContent == false
          || data.minimumViewerAge >= 18);
    }

    function validRecordMetadata(data) {
      return validOriginalLanguage(data)
        && validRecordIdentity(data)
        && validAnonymousLock(data)
        && validAdultMetadata(data);
    }

    function validRecordCreateMetadata(data) {
      return validRecordMetadata(data)
        && validRecordCreateMode(data);
    }

    function validProfileMetadata(data) {
      return !data.keys().hasAny(["biologicalSex"])
        || data.biologicalSex in [
          "",
          "preferNotToSay",
          "female",
          "male",
          "intersex",
          "notListed"
        ];
    }

    match /Records/{recordId} {
      allow get, list: if canReadPublicRecord(resource.data)
        || isOwner(resource.data.ownerId);

      allow create: if isOwner(request.resource.data.ownerId)
        && validRecordCreateMetadata(request.resource.data);

      allow update: if isOwner(resource.data.ownerId)
        && isNotAnonymousLocked(resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && anonymousLockUnchanged()
        && validRecordMetadata(request.resource.data);

      allow delete: if isOwner(resource.data.ownerId)
        && isNotAnonymousLocked(resource.data);
    }

    match /users/{userId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && validProfileMetadata(request.resource.data);

      match /savedRecords/{recordId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && validRecordMetadata(request.resource.data);
      }

      match /collections/{collectionId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;

        match /records/{recordId} {
          allow read, delete: if isSignedIn() && request.auth.uid == userId;
          allow create, update: if isSignedIn()
            && request.auth.uid == userId
            && validRecordMetadata(request.resource.data);
        }
      }
    }
  }
}
