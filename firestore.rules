rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && ownerId is string && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isTrustedServer() {
      return isAdmin()
        || (isSignedIn()
          && request.auth.token.firebase.sign_in_provider == "custom"
          && request.auth.token.server == true);
    }

    function validLanguage(language) {
      return language in ["en", "zh", "es"];
    }

    function validDreamDateStatus(status) {
      return status in ["known", "unknown", "hidden"];
    }

    function validSharingMode(mode) {
      return mode in [
        "private",
        "stats_only",
        "anonymous_public",
        "pseudonym_public",
        "redacted_public"
      ];
    }

    function validPrivacyOnboardingChoice(choice) {
      return choice in ["private", "stats_only", "anonymous_public", "dream_by_dream"];
    }

    function validVisibility(visibility) {
      return visibility in ["private", "public", "stats_only"];
    }

    function isPublicSharingMode(mode) {
      return mode in [
        "anonymous_public",
        "pseudonym_public",
        "redacted_public"
      ];
    }

    function optionalString(data, field, maxSize) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || (data[field] is string && data[field].size() <= maxSize);
    }

    function requiredString(data, field, minSize, maxSize) {
      return data.keys().hasAny([field])
        && data[field] is string
        && data[field].size() >= minSize
        && data[field].size() <= maxSize;
    }

    function optionalBool(data, field) {
      return !data.keys().hasAny([field]) || data[field] == null || data[field] is bool;
    }

    function optionalNumber(data, field, minValue, maxValue) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || (data[field] is number
          && data[field] >= minValue
          && data[field] <= maxValue);
    }

    function optionalNullableNumber(data, field, minValue, maxValue) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || (data[field] is number
          && data[field] >= minValue
          && data[field] <= maxValue);
    }

    function optionalList(data, field, maxSize) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || (data[field] is list && data[field].size() <= maxSize);
    }

    function optionalMap(data, field) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || data[field] is map;
    }

    function optionalTimestampOrString(data, field, maxSize) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || data[field] is timestamp
        || (data[field] is string && data[field].size() <= maxSize);
    }

    function validOptionalAge(data, field) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || data[field] == ""
        || (data[field] is number && data[field] >= 0 && data[field] <= 120);
    }

    function validOptionalLanguageField(data, field) {
      return !data.keys().hasAny([field]) || data[field] == null || validLanguage(data[field]);
    }

    function validOptionalDreamDateStatusField(data, field) {
      return !data.keys().hasAny([field])
        || data[field] == null
        || validDreamDateStatus(data[field]);
    }

    function recordRequiresAdult(data) {
      return (data.keys().hasAny(["adultContent"]) && data.adultContent == true)
        || (data.keys().hasAny(["minimumViewerAge"]) && data.minimumViewerAge >= 18);
    }

    function isAgeVerifiedAdult() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.age >= 18;
    }

    function canReadPublicDreamMirror(data) {
      return !recordRequiresAdult(data) || isAgeVerifiedAdult();
    }

    function validAdultMetadata(data) {
      return optionalBool(data, "adultContent")
        && optionalNumber(data, "minimumViewerAge", 0, 120)
        && (!data.keys().hasAll(["adultContent", "minimumViewerAge"])
          || data.adultContent == false
          || data.minimumViewerAge >= 18);
    }

    function anonymousLockUnchanged() {
      return (!resource.data.keys().hasAny(["anonymousLocked"])
          && !request.resource.data.keys().hasAny(["anonymousLocked"]))
        || (resource.data.keys().hasAny(["anonymousLocked"])
          && request.resource.data.keys().hasAny(["anonymousLocked"])
          && request.resource.data.anonymousLocked == resource.data.anonymousLocked);
    }

    function validProfileMetadata(data, userId) {
      return data.keys().hasAny(["uid"])
        && data.uid == userId
        && optionalString(data, "email", 254)
        && optionalString(data, "displayName", 120)
        && optionalString(data, "country", 120)
        && validOptionalAge(data, "age")
        && optionalBool(data, "showAge")
        && optionalBool(data, "showEmail")
        && optionalBool(data, "showBiologicalSex")
        && (!data.keys().hasAny(["biologicalSex"])
          || data.biologicalSex in [
            "",
            "preferNotToSay",
            "female",
            "male",
            "intersex",
            "notListed"
          ])
        && (!data.keys().hasAny(["preferredLanguage"])
          || validLanguage(data.preferredLanguage))
        && (!data.keys().hasAny(["defaultSharingMode"])
          || validSharingMode(data.defaultSharingMode))
        && optionalBool(data, "defaultResearchConsent")
        && optionalBool(data, "defaultPublicConsent")
        && optionalBool(data, "defaultIncludeInResearchStats")
        && optionalString(data, "defaultPseudonym", 120)
        && optionalBool(data, "defaultApplyToImports")
        && optionalBool(data, "defaultApplyToSingleDreams")
        && optionalBool(data, "requireReviewBeforePublic")
        && optionalBool(data, "skipAdultContentForBulkPublic")
        && optionalBool(data, "skipHighSensitivityForBulkPublic")
        && optionalNumber(data, "sensitivityAutoSkipThreshold", 1, 4)
        && optionalString(data, "privacyDefaultsUpdatedBy", 128)
        && optionalTimestampOrString(data, "privacyDefaultsUpdatedAt", 80)
        && optionalTimestampOrString(data, "createdAt", 80)
        && optionalTimestampOrString(data, "updatedAt", 80)
        && optionalBool(data, "privacyOnboardingCompleted")
        && (!data.keys().hasAny(["privacyOnboardingChoice"])
          || validPrivacyOnboardingChoice(data.privacyOnboardingChoice))
        && optionalMap(data, "privacySettings")
        && optionalString(data, "joinedAt", 32);
    }

    function validCustomTagCategory(category) {
      return category in [
        "Environment",
        "Entities",
        "Anomalies",
        "Emotions",
        "Styles",
        "Eras",
        "Weather",
        "Dream Types",
        "Perspective",
        "Psychological Observables",
        "Dream Analysis",
        "Custom"
      ];
    }

    function validCustomTagData(data, tagId) {
      return data.keys().hasAll(["slug", "name", "category"])
        && data.slug == tagId
        && data.slug is string
        && data.slug.size() >= 2
        && data.slug.size() <= 120
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 80
        && optionalString(data, "name_zh", 80)
        && optionalString(data, "name_es", 80)
        && validCustomTagCategory(data.category)
        && (!data.keys().hasAny(["status"])
          || data.status in ["active", "hidden", "pending_review"])
        && (!data.keys().hasAny(["custom"]) || data.custom == true)
        && (!data.keys().hasAny(["shared"]) || data.shared == true)
        && optionalString(data, "createdBy", 128)
        && optionalString(data, "updatedBy", 128)
        && optionalString(data, "lastUsedBy", 128);
    }

    function validImportMode(mode) {
      return mode in ["auto", "date_headings", "blank_lines", "csv", "json"];
    }

    function validImportStatus(status) {
      return status in [
        "uploaded",
        "parsing",
        "ai_tagging",
        "review_ready",
        "importing",
        "imported",
        "completed_with_errors",
        "failed"
      ];
    }

    function validImportBatchData(data) {
      return data.keys().hasAll(["ownerId", "status"])
        && data.ownerId is string
        && validImportStatus(data.status)
        && (!data.keys().hasAny(["privacyDefault"])
          || validSharingMode(data.privacyDefault))
        && (!data.keys().hasAny(["defaultVisibility"])
          || data.defaultVisibility == "private")
        && optionalString(data, "id", 128)
        && optionalString(data, "originalFileName", 240)
        && optionalString(data, "originalFileType", 120)
        && optionalNumber(data, "originalFileSize", 0, 6 * 1024 * 1024)
        && optionalString(data, "originalStoragePath", 512)
        && optionalMap(data, "storageUploadError")
        && (!data.keys().hasAny(["parserMode"])
          || validImportMode(data.parserMode))
        && (!data.keys().hasAny(["sourceFormat"])
          || validImportMode(data.sourceFormat))
        && optionalString(data, "parserVersion", 80)
        && optionalString(data, "autoTaggerVersion", 80)
        && optionalNumber(data, "dreamCount", 0, 250)
        && optionalNumber(data, "selectedCount", 0, 250)
        && optionalNumber(data, "draftCount", 0, 250)
        && optionalNumber(data, "approvedDraftCount", 0, 250)
        && optionalNumber(data, "importedCount", 0, 250)
        && optionalNumber(data, "linkedTranslationCount", 0, 250)
        && optionalNumber(data, "skippedCount", 0, 250)
        && optionalNumber(data, "failedCount", 0, 250)
        && optionalNumber(data, "importedRecordCount", 0, 250);
    }

    function validDraftStatus(status) {
      return status in ["draft", "review_ready", "importing", "imported", "skipped", "failed"];
    }

    function validImportDraftData(data, batchId) {
      return data.keys().hasAll(["ownerId", "importBatchId", "cleanedText"])
        && data.ownerId is string
        && data.importBatchId == batchId
        && data.cleanedText is string
        && data.cleanedText.size() >= 1
        && data.cleanedText.size() <= 120000
        && optionalString(data, "id", 128)
        && optionalString(data, "rawText", 120000)
        && optionalString(data, "detectedDate", 32)
        && optionalString(data, "detectedTime", 16)
        && optionalString(data, "dreamTime", 16)
        && optionalString(data, "dreamPeriod", 32)
        && optionalNumber(data, "dreamSequence", 1, 12)
        && validOptionalDreamDateStatusField(data, "dreamDateStatus")
        && optionalString(data, "detectedTitle", 220)
        && optionalString(data, "suggestedTitle", 220)
        && optionalString(data, "title", 220)
        && optionalString(data, "importMatchKey", 128)
        && optionalString(data, "titleSource", 80)
        && optionalNumber(data, "titleConfidence", 0, 1)
        && validOptionalLanguageField(data, "originalLanguage")
        && optionalList(data, "selectedTagSlugs", 120)
        && optionalList(data, "customTagLabels", 80)
        && optionalList(data, "suggestedTags", 120)
        && optionalString(data, "tagsSource", 80)
        && optionalBool(data, "tagsReviewedByUser")
        && optionalBool(data, "approved")
        && optionalBool(data, "needsUserReview")
        && optionalNumber(data, "boundaryConfidence", 0, 1)
        && optionalString(data, "boundaryReason", 160)
        && optionalNullableNumber(data, "orderIndex", 0, 1000000)
        && optionalNullableNumber(data, "sourceOrderIndex", 0, 1000000)
        && optionalNullableNumber(data, "sourceLineStart", 0, 10000000)
        && optionalNullableNumber(data, "sourceLineEnd", 0, 10000000)
        && (!data.keys().hasAny(["status"]) || validDraftStatus(data.status))
        && optionalString(data, "importedRecordId", 128)
        && optionalBool(data, "importedAsTranslation")
        && optionalString(data, "skippedReason", 120)
        && optionalString(data, "importError", 1000);
    }

    function validSavedRecordReference(data, userId) {
      return data.keys().hasAll(["ownerId"])
        && data.ownerId == userId
        && optionalString(data, "recordId", 128)
        && optionalString(data, "title", 220)
        && optionalString(data, "text", 120000)
        && optionalString(data, "originalText", 120000)
        && optionalList(data, "tags", 160)
        && optionalBool(data, "isPublic")
        && (!data.keys().hasAny(["visibility"]) || validVisibility(data.visibility))
        && (!data.keys().hasAny(["sharingMode"]) || validSharingMode(data.sharingMode))
        && validAdultMetadata(data);
    }

    function ownsRecordDocument(recordId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/Records/$(recordId))
        && get(/databases/$(database)/documents/Records/$(recordId)).data.ownerId == request.auth.uid;
    }

    function noForbiddenPublicDreamFields(data) {
      return !data.keys().hasAny([
        "ownerId",
        "creatorId",
        "userId",
        "uid",
        "email",
        "creatorEmail",
        "privateText",
        "privateTitle",
        "privateNotes",
        "sensitivityNotes",
        "dreamText",
        "dream_text",
        "originalText",
        "rawText",
        "cleanedText",
        "importRawText",
        "importBatchId",
        "importDraftId",
        "importMatchKey",
        "sourceFileName",
        "sourceLineStart",
        "sourceLineEnd"
      ]);
    }

    function publicDreamSourceRecordAllowsMirror(data, recordId) {
      return exists(/databases/$(database)/documents/Records/$(recordId))
        && get(/databases/$(database)/documents/Records/$(recordId)).data.sharingMode == data.sharingMode
        && get(/databases/$(database)/documents/Records/$(recordId)).data.isPublic == true
        && get(/databases/$(database)/documents/Records/$(recordId)).data.publicConsent == true
        && isPublicSharingMode(get(/databases/$(database)/documents/Records/$(recordId)).data.sharingMode);
    }

    function redactedPublicDreamUsesReviewedText(data, recordId) {
      return data.sharingMode != "redacted_public"
        || (exists(/databases/$(database)/documents/Records/$(recordId))
          && get(/databases/$(database)/documents/Records/$(recordId)).data.keys().hasAny(["publicText"])
          && get(/databases/$(database)/documents/Records/$(recordId)).data.publicText is string
          && get(/databases/$(database)/documents/Records/$(recordId)).data.publicText.size() > 0
          && get(/databases/$(database)/documents/Records/$(recordId)).data.redactionStatus == "user_confirmed"
          && data.publicText == get(/databases/$(database)/documents/Records/$(recordId)).data.publicText
          && data.publicText != get(/databases/$(database)/documents/Records/$(recordId)).data.dream_text
          && (!get(/databases/$(database)/documents/Records/$(recordId)).data.keys().hasAny(["originalText"])
            || data.publicText != get(/databases/$(database)/documents/Records/$(recordId)).data.originalText));
    }

    function validPublicDreamMirror(data, recordId) {
      return data.keys().hasOnly([
          "publicTitle",
          "publicText",
          "publicTags",
          "publicLanguage",
          "dateBucket",
          "publicDate",
          "pseudonym",
          "anonymousLabel",
          "publicCreatedAt",
          "publicConsent",
          "adultContent",
          "contentWarnings",
          "originalLanguage",
          "sharingMode",
          "publicTranslations",
          "translationLanguages",
          "translationSource"
        ])
        && noForbiddenPublicDreamFields(data)
        && data.keys().hasAll(["publicText", "publicLanguage", "originalLanguage", "sharingMode", "publicConsent", "adultContent"])
        && requiredString(data, "publicText", 1, 120000)
        && optionalString(data, "publicTitle", 220)
        && optionalList(data, "publicTags", 160)
        && validLanguage(data.publicLanguage)
        && validLanguage(data.originalLanguage)
        && optionalString(data, "dateBucket", 16)
        && optionalString(data, "publicDate", 16)
        && optionalString(data, "pseudonym", 120)
        && optionalString(data, "anonymousLabel", 120)
        && optionalTimestampOrString(data, "publicCreatedAt", 80)
        && data.publicConsent == true
        && data.adultContent is bool
        && optionalList(data, "contentWarnings", 40)
        && validPublicTranslations(data)
        && optionalList(data, "translationLanguages", 3)
        && (!data.keys().hasAny(["translationSource"])
          || data.translationSource == "recorder_provided")
        && validSharingMode(data.sharingMode)
        && isPublicSharingMode(data.sharingMode)
        && publicDreamSourceRecordAllowsMirror(data, recordId)
        && redactedPublicDreamUsesReviewedText(data, recordId);
    }

    function validPublicTranslation(value) {
      return value is map
        && value.keys().hasOnly(["title", "text", "excerpt"])
        && value.keys().hasAll(["text"])
        && requiredString(value, "text", 1, 120000)
        && optionalString(value, "title", 220)
        && optionalString(value, "excerpt", 800);
    }

    function validPublicTranslations(data) {
      return !data.keys().hasAny(["publicTranslations"])
        || (data.publicTranslations is map
          && data.publicTranslations.keys().hasOnly(["en", "zh", "es"])
          && (!data.publicTranslations.keys().hasAny(["en"])
            || validPublicTranslation(data.publicTranslations.en))
          && (!data.publicTranslations.keys().hasAny(["zh"])
            || validPublicTranslation(data.publicTranslations.zh))
          && (!data.publicTranslations.keys().hasAny(["es"])
            || validPublicTranslation(data.publicTranslations.es)));
    }

    function validResearchSignal(data, signalId) {
      return data.keys().hasOnly([
          "signalVersion",
          "recordIdHash",
          "userGroupHash",
          "language",
          "languageMissing",
          "monthBucket",
          "yearBucket",
          "period",
          "dreamLengthBucket",
          "tagSlugs",
          "selectedTagSlugs",
          "confirmedTagSlugs",
          "aiSuggestedTagSlugs",
          "emotionTags",
          "settingTags",
          "entityTags",
          "dreamTypeTags",
          "psychologicalObservationTags",
          "adultContent",
          "sensitivityLevelBucket",
          "importSourceType",
          "titleSource",
          "sharingMode",
          "tagSource",
          "confirmedByUser",
          "hasUnconfirmedAiTags"
        ])
        && data.keys().hasAll([
          "signalVersion",
          "recordIdHash",
          "userGroupHash",
          "language",
          "dreamLengthBucket",
          "adultContent",
          "sensitivityLevelBucket",
          "sharingMode",
          "confirmedByUser",
          "hasUnconfirmedAiTags"
        ])
        && data.signalVersion == "2026.1"
        && data.recordIdHash == signalId
        && requiredString(data, "recordIdHash", 1, 80)
        && requiredString(data, "userGroupHash", 1, 80)
        && validLanguage(data.language)
        && optionalBool(data, "languageMissing")
        && optionalString(data, "monthBucket", 16)
        && optionalString(data, "yearBucket", 8)
        && optionalString(data, "period", 32)
        && data.dreamLengthBucket in ["empty", "short", "medium", "long", "very_long"]
        && optionalList(data, "tagSlugs", 160)
        && optionalList(data, "selectedTagSlugs", 160)
        && optionalList(data, "confirmedTagSlugs", 160)
        && optionalList(data, "aiSuggestedTagSlugs", 160)
        && optionalList(data, "emotionTags", 80)
        && optionalList(data, "settingTags", 80)
        && optionalList(data, "entityTags", 80)
        && optionalList(data, "dreamTypeTags", 80)
        && optionalList(data, "psychologicalObservationTags", 80)
        && data.adultContent is bool
        && data.sensitivityLevelBucket in ["none", "low", "medium", "high", "restricted"]
        && optionalString(data, "importSourceType", 40)
        && optionalString(data, "titleSource", 80)
        && validSharingMode(data.sharingMode)
        && (data.sharingMode == "stats_only" || isPublicSharingMode(data.sharingMode))
        && optionalString(data, "tagSource", 80)
        && data.confirmedByUser is bool
        && data.hasUnconfirmedAiTags is bool;
    }

    function canReadResearchSignal(data, signalId) {
      return validResearchSignal(data, signalId)
        && (!data.adultContent || isAgeVerifiedAdult());
    }

    function validOwnerAuditData(data) {
      return data.keys().hasAll(["ownerId"])
        && data.ownerId == request.auth.uid
        && (!data.keys().hasAny(["userId"]) || data.userId == request.auth.uid);
    }

    match /PublicDreams/{recordId} {
      allow get, list: if canReadPublicDreamMirror(resource.data);

      allow create, update: if validPublicDreamMirror(request.resource.data, recordId)
        && (isTrustedServer() || ownsRecordDocument(recordId));

      allow delete: if isTrustedServer() || ownsRecordDocument(recordId);
    }

    match /ResearchSignals/{signalId} {
      allow get, list: if canReadResearchSignal(resource.data, signalId);

      allow create, update: if (isTrustedServer() || isSignedIn())
        && validResearchSignal(request.resource.data, signalId);

      allow delete: if isTrustedServer() || isSignedIn();
    }

    match /ConsentEvents/{eventId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && validOwnerAuditData(request.resource.data);
      allow update, delete: if false;
    }

    match /BulkPrivacyJobs/{jobId} {
      allow read, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && validOwnerAuditData(request.resource.data);
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && validOwnerAuditData(request.resource.data);
    }

    match /Records/{recordId} {
      allow get, list: if isOwner(resource.data.ownerId);

      allow create: if isOwner(request.resource.data.ownerId);

      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId
        && anonymousLockUnchanged();

      allow delete: if isOwner(resource.data.ownerId);
    }

    match /ImportBatches/{batchId} {
      allow read, delete: if isOwner(resource.data.ownerId);

      allow create: if isOwner(request.resource.data.ownerId)
        && validImportBatchData(request.resource.data);

      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.ownerId == resource.data.ownerId
        && validImportBatchData(request.resource.data);

      match /DraftDreams/{draftId} {
        allow read, delete: if isOwner(resource.data.ownerId);

        allow create: if isOwner(request.resource.data.ownerId)
          && validImportDraftData(request.resource.data, batchId);

        allow update: if isOwner(resource.data.ownerId)
          && request.resource.data.ownerId == resource.data.ownerId
          && validImportDraftData(request.resource.data, batchId);
      }
    }

    match /customTags/{tagId} {
      allow read: if true;

      allow create, update: if isSignedIn()
        && validCustomTagData(request.resource.data, tagId);

      allow delete: if false;
    }

    match /users/{userId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;

      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && validProfileMetadata(request.resource.data, userId);

      match /savedRecords/{recordId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && validSavedRecordReference(request.resource.data, userId);
      }

      match /following/{recorderId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.ownerId == userId
          && request.resource.data.recorderId == recorderId
          && optionalString(request.resource.data, "displayName", 120)
          && optionalString(request.resource.data, "email", 254);
      }

      match /collections/{collectionId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.ownerId == userId
          && request.resource.data.collectionId == collectionId
          && optionalString(request.resource.data, "name", 120);

        match /records/{recordId} {
          allow read, delete: if isSignedIn() && request.auth.uid == userId;

          allow create, update: if isSignedIn()
            && request.auth.uid == userId
            && validSavedRecordReference(request.resource.data, userId);
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
